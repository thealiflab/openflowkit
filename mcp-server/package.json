{
  "name": "@openflowkit/mcp-server",
  "version": "0.1.0",
  "description": "Provider-free Model Context Protocol server for OpenFlowKit — give Claude Desktop, Cursor, Windsurf, and other MCP clients first-class diagramming tools.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openflowkit",
    "diagram",
    "flowchart",
    "mermaid",
    "claude",
    "cursor",
    "windsurf",
    "local-first"
  ],
  "homepage": "https://github.com/Vrun-design/openflowkit#readme",
  "bugs": "https://github.com/Vrun-design/openflowkit/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vrun-design/openflowkit.git",
    "directory": "mcp-server"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "openflowkit-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:icons": "node scripts/build-icon-manifest.mjs",
    "prebuild": "npm run build:icons",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest --config vitest.config.ts --run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  }
}
